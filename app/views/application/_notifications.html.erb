<% show_debugging = Rails.env.development? && false %>
<% if notice || alert || show_debugging %>
    <%= tag.div class: "notification" do %>
        <%= tag.p debug(params), class: "container" if show_debugging %>
        <%= tag.p notice, class: "notification is-warning container" if notice %>
        <%= tag.p alert, class: "notification is-danger container" if alert %>
    <% end %>
<% end %>
