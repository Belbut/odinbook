<h2>Log in</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="field">
    <%= f.label :email %><br>
    <%= f.email_field :email, value:"test@test.com", autofocus: true, autocomplete: "email" %>
  </div>

  <div class="field">
    <%= f.label :password %><br>
    <%= f.password_field :password, value: "123456", autocomplete: "current-password" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="field">
      <%= f.check_box :remember_me %>
      <%= f.label :remember_me %>
    </div>
  <% end %>

  <div class="actions">
    <%= f.submit "Log in" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>

<div>
  <h2>Demo logins</h2>
  <p> You can test the social network by logging with one of the following accounts to see it in action</p>

  <div>
  <div><strong>Email:</strong> test@test.com</div>
  <div><strong>Password:</strong> 123456</div>
  </div>
<%# TODO: when using stimulus add a click option to write the log in on the form and add another account to log in for testing %>
</div>

