<h1>Friends#index</h1>
<p>Find me in app/views/friends/index.html.erb</p>

<h2>Friends:</h2>
<%= render "shared/card_grid", collection: @friends_profiles, precompute: @precompute %>

<% if current_user == @user %>
    <h2>Friends Invitations:</h2>
    <%= render "shared/card_grid", collection: @pending_incoming_fr_profiles, precompute: @precompute %>

    <h2>Friends Pending:</h2>
    <%= render "shared/card_grid", collection: @pending_outgoing_fr_profiles, precompute: @precompute %>
<% end %>
