    <%# partial parameters: post ; optional: nil %>

    <%= render "profiles/user_identity_header", user: current_user %>

    <%= form_with model: post do |form| %>
        <%= form.hidden_field :category, value: post.category %>
        <div>
            <%= form.textarea :body, class:"textarea", size: "100x8", placeholder: "What do you want to share?" %>
        </div>

        <div class="controls is-flex is-justify-content-space-between is-align-items-center mt-3">
            <div class="field mb-0">
                <div class="file has-name">
                    <label class="file-label">
                        <input class="file-input" type="file" name="post[added_files][]" multiple>
                        <span class="file-cta">
                            <span class="file-icon">
                                <i class="fa fa-upload"></i>
                            </span>
                            <span class="file-label">
                                Choose a file…
                            </span>
                        </span>
                        <span class="file-name">
                            No file selected
                        </span>
                    </label>
                </div>
            </div>

            <div>
                <%= form.submit "Publish", class:"button is-dark" %>
            </div>
        </div>
<% end %>

