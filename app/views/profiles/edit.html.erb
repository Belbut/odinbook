<main>
    <%= render "profile_header", profile: @profile, user: @user %>

    <section class="box">
        <%= form_with model: @profile do |form| %>

            <h1 class="title is-4">Bibliography</h1>

            <div class="field">
                <%= form.label :name, class: "label" %>

                <div class="control">
                <%= form.text_field :name,
                        class: "input" %>
                </div>
            </div>

            <div class="field">
                <%= form.label :birthday, class: "label" %>

                <div class="control">
                <%= form.date_field :birthday,
                        class: "input" %>
                </div>
            </div>

            <div class="field">
                <%= form.label :location, class: "label" %>

                <div class="control">
                <%= form.text_field :location,
                        class: "input" %>
                </div>
            </div>

            <div class="level mt-4">
                <div class="level-right">
                <div class="level-item">
                    <%= form.submit "Publish",
                        class: "button is-dark" %>
                </div>
                </div>
            </div>

        <% end %>
    </section>
</main>
