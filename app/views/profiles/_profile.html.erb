<%# partial parameters: profile:[profile] ; optional:common_friends_precomputed, interactions_precomputed  %>
<% common_friends_precomputed = common_friends_precomputed || nil %>
<% interactions_precomputed = interactions_precomputed || nil %>

<div class="profile">
    <%# <div><%= render %>
    <div><%= link_to(profile.name, user_profile_path(profile.user)) %></div>
    <div><%= image_tag profile.avatar.representation(resize_to_fill: [100, 100]) %></div>
    <div><%= render_common_friends_count(current_user, profile.user, precomputed_common_friends: common_friends_precomputed) %></div>
    <div><%= render_user_friend_request_action(current_user, profile.user, precomputed_status: interactions_precomputed) %></div>
</div>
