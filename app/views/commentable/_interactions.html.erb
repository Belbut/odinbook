<%# partial parameters: content[Content]; %>

<section class="interactions">
    <span>Number of reactions <%= link_to content.likes.size, post_likes_path(content) %></span>
    <div>
        <%= render_like_toggle content %>
        <%= link_to "Reply", reply_path(content) %>
        <%= button_to "Share" %>
        <%= edit_link_for content %>
    </div>
</section>
